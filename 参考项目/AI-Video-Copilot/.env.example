# ============================================================
# AI Video Copilot — Environment Configuration
# ============================================================
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.
# ============================================================

# --- OpenAI-compatible API ---
# For Qwen (DashScope):
OPENAI_API_KEY=sk-your-api-key-here
OPENAI_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
MODEL_NAME=qwen-plus

# For OpenAI directly:
# OPENAI_API_KEY=sk-...
# OPENAI_BASE_URL=https://api.openai.com/v1
# MODEL_NAME=gpt-4o

# --- Application ---
MAX_FILE_SIZE_MB=500
LOG_LEVEL=INFO

# --- Volcengine / Doubao Seedance Video Generation ---
# Get your API key from: https://console.volcengine.com/ark
VOLC_API_KEY=your-volcengine-api-key-here
VOLC_BASE_URL=https://ark.cn-beijing.volces.com/api/v3
VOLC_MODEL_ID=doubao-seedance-1-5-pro-251215
