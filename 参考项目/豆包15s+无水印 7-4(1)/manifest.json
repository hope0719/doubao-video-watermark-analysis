{
  "manifest_version": 3,
  "name": "豆包15s+无水印 7.4",
  "version": "10.2.14",
  "description": "集成 5/10/15 秒时长切换与豆包图片、视频无水印下载。",
  "author": "mr_dadong",
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icon.png",
      "32": "icon.png",
      "48": "icon.png",
      "64": "icon.png",
      "128": "icon.png"
    }
  },
  "icons": {
    "16": "icon.png",
    "32": "icon.png",
    "48": "icon.png",
    "64": "icon.png",
    "128": "icon.png"
  },
  "permissions": ["downloads", "storage", "tabs", "activeTab", "scripting", "debugger"],
  "host_permissions": [
    "*://*.doubao.com/*",
    "*://*.dola.com/*",
    "https://api-normal.doubao.com/*",
    "https://*.snssdk.com/*",
    "https://*.douyin.com/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["*://*.doubao.com/*"],
      "js": ["content.js"],
      "run_at": "document_start",
      "world": "MAIN"
    },
    {
      "matches": ["*://*.doubao.com/*"],
      "js": ["forwarder.js"],
      "run_at": "document_idle"
    },
    {
      "matches": ["*://*.doubao.com/*"],
      "js": ["directory.js"],
      "css": ["directory.css"]
    }
  ]
}
